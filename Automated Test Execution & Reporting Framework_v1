import pandas as pd
import random

# Read Excel File
df = pd.read_excel(r"C:\Users\sg97976\Desktop\python\intropython\Projects\mega_project-\bcm_testcases.xlsx")

pass_count = 0
fail_count = 0

log_file = open("execution_log.txt", "w")
report_file = open("report.txt", "w")

for index, row in df.iterrows():

    test_input = row["Input"]
    expected = row["Expected"]

    # BCM Logic
    if test_input == "lock":
        actual = random.choice([                     # using random module to choose the ECU output
        "Door Locked",                        # Correct response
        "Door Unlocked",                      # Wrong response
        "ECU Timeout"                         # Failure simulation
    ])
        
    elif test_input == "unlock":
         actual = random.choice([
        "Door Unlocked",
        "Door Locked",
        "Communication Error"
    ])

    else:
        actual = "Invalid Input"

    # PASS / FAIL
    if actual == expected:
        status = "PASS"
        pass_count += 1
    else:
        status = "FAIL"
        fail_count += 1

    result = f"{row['TC_ID']} --> {status}"

    print(result)

    log_file.write(result + "\n")
    report_file.write(
        f"{row['TC_ID']} | Expected: {expected} | Actual: {actual} | {status}\n"
    )

log_file.close()
report_file.close()